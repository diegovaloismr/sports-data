# Copie este arquivo para ".env" e preencha com os valores reais.
# NUNCA versionar o .env nem o JSON da Service Account (já estão no .gitignore).

# Caminho local para o arquivo JSON da Service Account do Google Cloud
# (Google Sheets API + Google Drive API habilitadas, planilhas compartilhadas com o e-mail da service account)
FCA_GOOGLE_SERVICE_ACCOUNT_FILE=./credentials/service_account.json

# Planilhas de Vagas e de Modalidades/Locais
FCA_SHEET_ID_VAGAS=
FCA_SHEET_ID_LOCAIS=

# Planilhas de matrícula (uma por modalidade)
FCA_SHEET_ID_NATACAO=
FCA_SHEET_ID_FUTEBOL=
FCA_SHEET_ID_BASQUETE=
FCA_SHEET_ID_GINASTICA=
FCA_SHEET_ID_VOLEIBOL=
FCA_SHEET_ID_JIUJITSU=
FCA_SHEET_ID_TENIS=
FCA_SHEET_ID_TRIATHLON=

# Caminho do banco SQLite local
FCA_DATABASE_PATH=./data/fca.db
